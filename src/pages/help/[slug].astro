---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { helpPages, type HelpPage } from '@/data/helpPages';

export function getStaticPaths() {
  return helpPages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

interface Props { page: HelpPage }
const { page } = Astro.props;
const site = Astro.site || new URL(Astro.url.origin);
const canonicalPath = `/help/${page.slug}/`;
const related = helpPages.filter((item) => item.slug !== page.slug && (item.category === page.category || (!item.appLabel && page.appLabel))).slice(0, 4);
const schemas = [
  {
    '@context': 'https://schema.org', '@type': 'Article',
    headline: page.h1, description: page.description,
    datePublished: page.updated, dateModified: page.updated,
    author: { '@type': 'Organization', name: 'GameHelp India' },
    publisher: { '@type': 'Organization', name: 'GameHelp India', url: new URL('/', site) },
    mainEntityOfPage: new URL(canonicalPath, site), inLanguage: 'en-IN'
  },
  {
    '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site) },
      { '@type': 'ListItem', position: 2, name: 'Help guides', item: new URL('/help/', site) },
      { '@type': 'ListItem', position: 3, name: page.h1, item: new URL(canonicalPath, site) }
    ]
  },
  {
    '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: page.faq.map(([question, answer]) => ({ '@type': 'Question', name: question, acceptedAnswer: { '@type': 'Answer', text: answer } }))
  }
];
---
<BaseLayout title={page.title} description={page.description} {canonicalPath} {schemas}>
  <main id="main">
    <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>›</span><a href="/help/">Help guides</a><span>›</span><span>{page.h1}</span></nav>
    <section class="page-hero">
      <span class="kicker">{page.category} help · Updated {new Date(`${page.updated}T00:00:00`).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })}</span>
      <h1>{page.h1}</h1>
      <p>{page.description}</p>
      <div class="independent-note"><strong>Not official support:</strong> GameHelp India {page.appLabel ? `does not operate or represent the ${page.appLabel}.` : 'does not operate online games or payment wallets.'} We cannot access accounts, release withdrawals or process refunds.</div>
    </section>

    <div class="article-layout">
      <article class="article">
        <div class="quick-answer"><strong>Quick answer</strong>{page.quickAnswer}</div>
        <p>{page.context}</p>

        <h2>What to do now</h2>
        <ol class="number-list">{page.immediateSteps.map((step) => <li>{step}</li>)}</ol>

        <h2>Evidence to save</h2>
        <p>Mask unrelated personal information before sending evidence. Keep the original files privately in case a bank or authority requests them.</p>
        <ul class="evidence-list">{page.evidence.map((item) => <li>{item}</li>)}</ul>

        <h2>Escalation path</h2>
        <ol class="number-list">{page.escalation.map((step) => <li>{step}</li>)}</ol>

        <h2>Do not do this</h2>
        <ul class="avoid-list">{page.avoid.map((item) => <li>{item}</li>)}</ul>

        <h2>Prepare a written complaint</h2>
        <p>A clear chronology helps the operator, payment provider, bank or cybercrime team understand what happened. Include facts and transaction references without making unsupported claims.</p>
        <div class="actions"><a class="btn btn-primary" href={`/tools/complaint-draft/?issue=${encodeURIComponent(page.category)}&app=${encodeURIComponent(page.appLabel || '')}`}>Create private complaint draft</a><a class="btn btn-secondary" href="https://cybercrime.gov.in/" rel="noopener noreferrer">Government portal ↗</a></div>

        <h2>Frequently asked questions</h2>
        <div class="faq">{page.faq.map(([question, answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}</div>

        <h2>Related independent guides</h2>
        <div class="related-list">{related.map((item) => <a href={`/help/${item.slug}/`}>{item.h1} <span>→</span></a>)}</div>
      </article>

      <aside class="sidebar" aria-label="Important help information">
        <div class="side-card danger-card"><h2>Immediate financial fraud?</h2><p><strong>Call 1930.</strong> Then file a Report &amp; Track complaint at the Government of India portal.</p><a href="https://cybercrime.gov.in/" rel="noopener noreferrer">cybercrime.gov.in ↗</a></div>
        <div class="side-card"><h2>Keep private</h2><ul><li>OTP and UPI PIN</li><li>Full Aadhaar or PAN</li><li>Complete bank statement</li><li>Card CVV or PIN</li><li>Remote-access codes</li></ul></div>
        <div class="side-card"><h2>Editorial standard</h2><p>We use neutral language, do not claim to be official support, and do not publish real-money game referrals or APK downloads.</p><a href="/editorial-policy/">Read our policy →</a></div>
      </aside>
    </div>
  </main>
</BaseLayout>
