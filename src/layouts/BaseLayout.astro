---
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  robots?: string;
  schemas?: Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  robots = 'index,follow,max-image-preview:large',
  schemas = []
} = Astro.props;

const siteName = 'GameHelp India';
const site = Astro.site || new URL(Astro.url.origin);
const canonical = new URL(canonicalPath, site);
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const supportTelegram = import.meta.env.PUBLIC_SUPPORT_TELEGRAM || '';
---
<!doctype html>
<html lang="en-IN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="theme-color" content="#0f766e" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL('/og-help.webp', site)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {schemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema).replace(/</g, '\\u003c')} />)}
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
  <div class="alert-strip"><strong>Financial fraud?</strong> Call <a href="tel:1930">1930</a> immediately · Government portal: <a href="https://cybercrime.gov.in/" rel="noopener noreferrer">cybercrime.gov.in</a></div>
  <header class="site-header">
    <a class="brand" href="/" aria-label="GameHelp India home"><span class="brand-mark">GH</span><span>GameHelp <em>India</em></span></a>
    <nav aria-label="Main navigation">
      <a href="/help/">Help guides</a>
      <a href="/tools/complaint-draft/">Complaint draft</a>
      <a href="/editorial-policy/">Our policy</a>
    </nav>
  </header>
  <slot />
  <footer>
    <div class="footer-grid">
      <div><a class="brand footer-brand" href="/"><span class="brand-mark">GH</span><span>GameHelp India</span></a><p>Independent consumer-safety information for online-game payment, account and APK issues.</p></div>
      <div><h2>Help</h2><a href="/help/online-game-withdrawal-pending/">Withdrawal pending</a><a href="/help/online-game-deposit-pending/">Deposit pending</a><a href="/help/report-online-game-fraud-india/">Report fraud</a></div>
      <div><h2>Trust</h2><a href="/about/">About</a><a href="/editorial-policy/">Editorial policy</a><a href="/privacy/">Privacy</a><a href="/disclaimer/">Disclaimer</a></div>
      {supportTelegram && <div><h2>Community</h2><a href={supportTelegram} rel="nofollow noopener noreferrer">Independent Telegram support</a><small>Never share OTP, PIN, KYC documents or send money to an admin.</small></div>}
    </div>
    <div class="footer-note"><strong>Not official support:</strong> We do not operate gaming apps, process deposits, release withdrawals, distribute APKs or accept financial documents. © 2026 GameHelp India.</div>
  </footer>
</body>
</html>
